{
  "manifest_version": 3,
  "name": "Beauty Shot",
  "description": "Generate beautiful screenshots of highlighted text",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["tailwind.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
